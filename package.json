{
  "name": "pi-kit",
  "version": "0.1.0",
  "private": true,
  "description": "个人 Pi Coding Agent 配置包：安全扩展和精简开发工作流。",
  "license": "MIT",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-kit"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate:resources": "node scripts/validate-resources.mjs",
    "test:safety": "node scripts/test-safety-guard.js",
    "test:ssh": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/test-ssh-remote.mjs",
    "validate": "npm run typecheck && npm run validate:resources"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./extensions/safety-guard/index.ts",
      "./extensions/ssh-remote/index.ts"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "typescript": "^6.0.3"
  }
}
